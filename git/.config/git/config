[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use 'n' and 'p' to move between diff sections
    light = false      # set to true if you're in a terminal w/ a light background color (e.g. Solarized Light)
    side-by-side = true
    line-numbers = true
    syntax-theme = Catppuccin Mocha

[merge]
    conflictstyle = zdiff3
